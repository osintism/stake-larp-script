{
  "manifest_version": 3,
  "name": "Google Authenticator",
  "description": "Two-step verification for your Google Account",
  "version": "6.0.3",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Google Authenticator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://*.stake.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
